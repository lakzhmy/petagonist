# Map tiles — MapLibre GL JS (open-source, no paid token required).
# By default the app uses token-free CARTO Voyager raster tiles (real streets).
# Set this to a full MapLibre style URL to override (e.g. a MapTiler/Stadia
# style with your own key for higher rate limits).
# VITE_MAP_STYLE_URL=https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
