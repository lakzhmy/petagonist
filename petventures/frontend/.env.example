# Map tiles — using MapLibre GL JS (open-source, no paid token required).
# Default uses a free demo style; swap for your own provider (MapTiler,
# Stadia, Protomaps, etc.) if you want higher rate limits.
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Optional: if you use a keyed provider like MapTiler, put the key here and
# reference it from the style URL.
# VITE_MAPTILER_KEY=
