# Mapillary access token — enables real street-level photos as panel scenes.
# Free: create an app at https://www.mapillary.com/dashboard/developers and copy
# its client token (format: MLY|<id>|<secret>). Without it, scenes fall back to
# drawn placeholders. Loaded from a .env at the repo root or backend/ dir.
# Both MAPILLARY_TOKEN and MapillaryToken are accepted.
MAPILLARY_TOKEN=

# Google Street View Static API key (alternative scene source — not wired).
STREETVIEW_API_KEY=

# Optional: URL of a running ComfyUI instance (generation is stubbed for now).
COMFYUI_URL=http://localhost:8188
